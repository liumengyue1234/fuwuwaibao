# ============================================
# 审思明辨——智判法案双擎系统 环境变量配置
# ============================================

# ============ 腾讯云配置 ============
# 腾讯云账号密钥 (用于访问腾讯云向量数据库等)
# 获取地址: https://console.cloud.tencent.com/cam/capi
TC_SECRET_ID=your_secret_id_here
TC_SECRET_KEY=your_secret_key_here

# 腾讯云地域
TC_REGION=ap-guangzhou

# ============ 腾讯混元大模型配置 ============
# 通过腾讯元器平台创建智能体获取
# 获取地址: https://yuanqi.tencent.com/
HUNYUAN_APP_ID=your_hunyuan_app_id
HUNYUAN_APP_KEY=your_hunyuan_app_key

# ============ 得理开放平台配置 ============
# 用于法律案例和法规检索
# API文档: https://open.delilegal.com/
# 测试环境无需注册，直接使用以下凭证
DELILEGAL_APP_ID=QthdBErlyaYvyXul
DELILEGAL_SECRET=EC5D455E6BD348CE8E18BE05926D2EBE

# ============ 腾讯文档配置 ============
# 用于诉讼策略报告导出
# 获取地址: https://docs.qq.com/
TENCENT_DOC_APP_ID=your_tencent_doc_app_id
TENCENT_DOC_SECRET=your_tencent_doc_secret

# ============ 应用配置 ============
# 应用端口
APP_PORT=8501

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 最大检索结果数
MAX_SEARCH_RESULTS=10

# 会话历史最大条数
MAX_HISTORY_LENGTH=40
